<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskBlaster.Dialogs.ConfigDialog"
        Width="560" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogSurfaceBrush}"
        Title="Settings">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="16">
        <TextBlock Grid.Row="0" Text="Scripts folder" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
            <TextBox Grid.Column="0" Name="ScriptsFolderBox" />
            <Button  Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseScripts" />
        </Grid>

        <TextBlock Grid.Row="2" Text="Forms folder" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
            <TextBox Grid.Column="0" Name="FormsFolderBox" />
            <Button  Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseForms" />
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Name="CancelButton" Content="Cancel" Click="OnCancel" />
            <Button Name="SaveButton"   Content="Save"   Click="OnSave" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
