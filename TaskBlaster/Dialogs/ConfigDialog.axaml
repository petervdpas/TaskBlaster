<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskBlaster.Dialogs.ConfigDialog"
        Width="560" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogSurfaceBrush}"
        Title="Settings">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="16">
        <TextBlock Grid.Row="0" Text="Theme" FontWeight="SemiBold" Margin="0,0,0,6" />
        <ComboBox  Grid.Row="1" Name="ThemeBox" HorizontalAlignment="Stretch" Margin="0,0,0,14" />

        <TextBlock Grid.Row="2" Text="Editor highlighter" FontWeight="SemiBold" Margin="0,0,0,6" />
        <ComboBox  Grid.Row="3" Name="HighlighterBox" HorizontalAlignment="Stretch" Margin="0,0,0,4">
            <ComboBoxItem Content="TextMate" Tag="TextMate" />
            <ComboBoxItem Content="Native"   Tag="Native"   />
        </ComboBox>
        <TextBlock Grid.Row="4" FontSize="11" Opacity="0.7" Margin="0,0,0,10"
                   Text="TextMate matches VS Code colours; Native uses AvaloniaEdit's built-in highlighter and scrolls noticeably smoother on larger files." />

        <CheckBox Grid.Row="5" Name="CodeFoldingBox" Content="Code folding" Margin="0,0,0,14" />

        <TextBlock Grid.Row="6" Text="Scripts folder" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Grid.Row="7" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
            <TextBox Grid.Column="0" Name="ScriptsFolderBox" />
            <Button  Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseScripts" />
        </Grid>

        <TextBlock Grid.Row="8" Text="Forms folder" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Grid.Row="9" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
            <TextBox Grid.Column="0" Name="FormsFolderBox" />
            <Button  Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseForms" />
        </Grid>

        <TextBlock Grid.Row="10" Text="Vault folder" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Grid.Row="11" ColumnDefinitions="*,Auto" Margin="0,0,0,14">
            <TextBox Grid.Column="0" Name="VaultFolderBox" />
            <Button  Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseVault" />
        </Grid>

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Name="CancelButton" Content="Cancel" Click="OnCancel" />
            <Button Name="SaveButton"   Content="Save"   Click="OnSave" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
