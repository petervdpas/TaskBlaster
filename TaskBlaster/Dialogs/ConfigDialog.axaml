<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskBlaster.Dialogs.ConfigDialog"
        Width="720" Height="540"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogSurfaceBrush}"
        Title="Settings">
    <Grid RowDefinitions="*,Auto" Margin="16">
        <TabControl Grid.Row="0">
            <TabItem Header="Display">
                <StackPanel Margin="4,12,4,4" Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Theme" FontWeight="SemiBold" />
                        <ComboBox Name="ThemeBox" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Editor highlighter" FontWeight="SemiBold" />
                        <ComboBox Name="HighlighterBox" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="TextMate" Tag="TextMate" />
                            <ComboBoxItem Content="Native"   Tag="Native"   />
                        </ComboBox>
                        <TextBlock FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                   Text="TextMate matches VS Code colours; Native uses AvaloniaEdit's built-in highlighter and scrolls noticeably smoother on larger files." />
                    </StackPanel>

                    <CheckBox Name="CodeFoldingBox" Content="Code folding" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Location">
                <StackPanel Margin="4,12,4,4" Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Scripts folder" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Name="ScriptsFolderBox" />
                            <Button  Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseScripts" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Forms folder" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Name="FormsFolderBox" />
                            <Button  Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseForms" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Vault folder" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Name="VaultFolderBox" />
                            <Button  Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowseVault" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="External">
                <Grid RowDefinitions="Auto,*,Auto,*" Margin="4,12,4,4">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <TextBlock Text="NuGet packages" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Name="AddNugetButton"    Content="Add .nupkg…" Click="OnAddNuget" />
                        <Button Name="RemoveNugetButton" Content="Remove"      Click="OnRemoveNuget" IsEnabled="False" />
                    </StackPanel>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <ListBox Name="NugetsList" SelectionChanged="OnNugetSelectionChanged" />
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,16,0,4">
                        <TextBlock Text="Loose DLLs" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Name="AddDllButton"    Content="Add DLL…" Click="OnAddDll" />
                        <Button Name="RemoveDllButton" Content="Remove"   Click="OnRemoveDll" IsEnabled="False" />
                    </StackPanel>
                    <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <ListBox Name="DllsList" SelectionChanged="OnDllSelectionChanged" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Name="CancelButton" Content="Cancel" Click="OnCancel" />
            <Button Name="SaveButton"   Content="Save"   Click="OnSave" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
