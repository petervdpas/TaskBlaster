<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskBlaster.Dialogs.PasswordDialog"
        Width="440" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogSurfaceBrush}"
        Title="Password">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="16">
        <TextBlock Grid.Row="0" Name="PromptText" TextWrapping="Wrap" Margin="0,0,0,10" />

        <TextBlock Grid.Row="1" Text="Password" FontWeight="SemiBold" Margin="0,0,0,4" />
        <Grid      Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <TextBox Grid.Column="0" Name="PasswordBox" PasswordChar="•" />
            <Button  Grid.Column="1" Name="RevealButton" Content="👁" Margin="8,0,0,0" Click="OnToggleReveal" />
        </Grid>

        <StackPanel Grid.Row="3" Name="ConfirmPanel" IsVisible="False" Margin="0,0,0,10">
            <TextBlock Text="Confirm password" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Name="ConfirmBox" PasswordChar="•" />
        </StackPanel>

        <TextBlock Grid.Row="4" Name="ErrorText"
                   Foreground="{DynamicResource SystemErrorTextColor}"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Name="CancelButton" Content="Cancel" Click="OnCancel" />
            <Button Name="OkButton"     Content="OK"     Click="OnOk" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
