<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskBlaster.Dialogs.InputDialog"
        Width="420" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogSurfaceBrush}"
        Title="Input">
    <Grid RowDefinitions="Auto,Auto,Auto" Margin="16">
        <TextBlock Grid.Row="0" Name="PromptText" TextWrapping="Wrap" Margin="0,0,0,10" />
        <TextBox   Grid.Row="1" Name="InputBox" Margin="0,0,0,14" />
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Name="CancelButton" Content="Cancel" Click="OnCancel" />
            <Button Name="OkButton"     Content="OK"     Click="OnOk" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
