<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TaskBlaster.Dialogs.SecretEntryDialog"
        Width="520" SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogSurfaceBrush}"
        Title="Secret">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="16">
        <TextBlock Grid.Row="0" Text="Category" FontWeight="SemiBold" Margin="0,0,0,4" />
        <ComboBox Grid.Row="1" Name="CategoryBox" Margin="0,0,0,10" HorizontalAlignment="Stretch" />

        <TextBlock Grid.Row="2" Text="Key" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox Grid.Row="3" Name="KeyBox" Margin="0,0,0,10" />

        <TextBlock Grid.Row="4" Text="Value" FontWeight="SemiBold" Margin="0,0,0,4" />
        <Grid Grid.Row="5" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <TextBox Grid.Column="0" Name="ValueBox" PasswordChar="•" AcceptsReturn="False" />
            <Button  Grid.Column="1" Name="ToggleRevealButton" Content="👁" Margin="8,0,0,0" Click="OnToggleReveal" />
        </Grid>

        <TextBlock Grid.Row="6" Text="Description (optional)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox Grid.Row="7" Name="DescriptionBox" AcceptsReturn="True" TextWrapping="Wrap" Height="64" Margin="0,0,0,10" />

        <TextBlock Grid.Row="8" Name="ErrorText"
                   Foreground="{DynamicResource SystemErrorTextColor}"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="9" Name="MetadataText"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   FontSize="11"
                   IsVisible="False"
                   Margin="0,0,0,8" />

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Name="CancelButton" Content="Cancel" Click="OnCancel" />
            <Button Name="SaveButton"   Content="Save"   Click="OnSave" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
