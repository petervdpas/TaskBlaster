<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="Color.Background">#1B1E21</Color>
  <Color x:Key="Color.Surface">#24282C</Color>

  <Color x:Key="Color.Border">#3A4046</Color>
  <Color x:Key="Color.BorderMuted">#2E3338</Color>

  <Color x:Key="Color.TextPrimary">#E6E6E6</Color>
  <Color x:Key="Color.TextMuted">#9A9A9A</Color>

  <Color x:Key="Color.Accent">#FF9800</Color>
  <Color x:Key="Color.Danger">#C95C5C</Color>
  <Color x:Key="Color.Success">#5CC97B</Color>

  <Color x:Key="SystemAccentColor">#FF9800</Color>
  <Color x:Key="SystemAccentColorLight1">#FFB74D</Color>
  <Color x:Key="SystemAccentColorDark1">#C77700</Color>

</ResourceDictionary>
