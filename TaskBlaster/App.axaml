<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dlg="clr-namespace:TaskBlaster.Dialogs"
             x:Class="TaskBlaster.App"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />

        <!-- Vertical splitter: column-resizing, 6px hit area, 2px visible line, hover-highlight. -->
        <Style Selector="GridSplitter.niceV">
            <Setter Property="Width" Value="6" />
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel Background="Transparent">
                        <Rectangle Name="PART_Bar"
                                   Width="2"
                                   HorizontalAlignment="Center"
                                   Fill="{TemplateBinding Background}" />
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="GridSplitter.niceV:pointerover /template/ Rectangle#PART_Bar">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Horizontal splitter: row-resizing, same idea rotated. -->
        <Style Selector="GridSplitter.niceH">
            <Setter Property="Height" Value="6" />
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel Background="Transparent">
                        <Rectangle Name="PART_Bar"
                                   Height="2"
                                   VerticalAlignment="Center"
                                   Fill="{TemplateBinding Background}" />
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="GridSplitter.niceH:pointerover /template/ Rectangle#PART_Bar">
            <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries />
            <dlg:ResourceKeyToBrushConverter x:Key="ResourceKeyToBrush" />
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#F3F3F3" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#2B2B2B" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
