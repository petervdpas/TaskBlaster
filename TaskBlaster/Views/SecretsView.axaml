<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:TaskBlaster.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="TaskBlaster.Views.SecretsView">
    <Grid>
        <Grid Name="LockedPanel" IsVisible="True">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="🔒  Vault is locked"  FontSize="18" HorizontalAlignment="Center" />
                <TextBlock Name="LockedHint" Text="Unlock to view secrets." HorizontalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <Button Name="UnlockButton" Content="🔓 Unlock" HorizontalAlignment="Center" Click="OnUnlockClicked" />
                <Button Name="ResetButton" Content="♻ Reset vault (forgot password)"
                        HorizontalAlignment="Center"
                        Foreground="{DynamicResource SystemErrorTextColor}"
                        Click="OnResetClicked" />
            </StackPanel>
        </Grid>

        <Grid Name="UnlockedPanel" IsVisible="False" ColumnDefinitions="200,4,*">
            <Border Grid.Column="0" BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Categories" FontWeight="SemiBold" Padding="10,8" />
                    <ListBox Grid.Row="1" Name="CategoriesList" SelectionChanged="OnCategorySelectionChanged" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Padding="8" BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Name="AddButton"    Content="➕ Add"    Click="OnAddClicked" />
                        <Button Name="EditButton"   Content="✏ Edit"   IsEnabled="False" Click="OnEditClicked" />
                        <Button Name="DeleteButton" Content="🗑 Delete" IsEnabled="False" Click="OnDeleteClicked" />
                        <Rectangle Width="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="6,2" />
                        <Button Name="CopyButton"   Content="📋 Copy value" IsEnabled="False" Click="OnCopyClicked" />
                        <Button Name="LockButton"   Content="🔒 Lock"    Click="OnLockClicked" />
                        <Rectangle Width="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="6,2" />
                        <Button Name="ChangePwButton" Content="🔑 Change password" Click="OnChangePasswordClicked" />
                        <Button Name="DestroyButton"  Content="🗑 Destroy vault"
                                Foreground="{DynamicResource SystemErrorTextColor}"
                                Click="OnDestroyClicked" />
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" Name="EntriesGrid"
                          x:DataType="views:SecretRow"
                          AutoGenerateColumns="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          SelectionChanged="OnEntrySelectionChanged"
                          DoubleTapped="OnEntryDoubleTapped">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category"      Binding="{Binding Category}"          Width="160" x:DataType="views:SecretRow" />
                        <DataGridTextColumn Header="Key"           Binding="{Binding Key}"               Width="200" x:DataType="views:SecretRow" />
                        <DataGridTextColumn Header="Description"   Binding="{Binding Description}"       Width="*"   x:DataType="views:SecretRow" />
                        <DataGridTextColumn Header="Updated (UTC)" Binding="{Binding UpdatedUtcDisplay}" Width="150" x:DataType="views:SecretRow" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="2" Name="EmptyLabel"
                           Text="No secrets yet. Click ➕ Add to create your first one."
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           HorizontalAlignment="Center"
                           Padding="20"
                           IsVisible="False" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
