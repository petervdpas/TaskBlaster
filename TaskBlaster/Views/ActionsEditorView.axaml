<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:forms="clr-namespace:TaskBlaster.Forms"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="200"
             x:Class="TaskBlaster.Views.ActionsEditorView">
    <Border BorderThickness="1" CornerRadius="4" Padding="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <Grid RowDefinitions="Auto,Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="Actions" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Name="AddButton" Content="+ Add action" Click="OnAdd" />
            </Grid>

            <TextBlock Grid.Row="1" FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="Buttons rendered at the bottom of the form. Submit validates and returns field values to the script; Dismiss closes the form without validating." />

            <DataGrid Grid.Row="2" Name="ActionsGrid"
                      x:DataType="forms:ActionEditor"
                      AutoGenerateColumns="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="ID" Width="*" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:ActionEditor">
                                <TextBox Text="{Binding Id, Mode=OneWay}"
                                         TextChanged="OnIdChanged"
                                         BorderThickness="1"
                                         Margin="2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Label" Width="*" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:ActionEditor">
                                <TextBox Text="{Binding Label, Mode=OneWay}"
                                         TextChanged="OnLabelChanged"
                                         Margin="2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Submit" Width="100" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:ActionEditor">
                                <CheckBox IsChecked="{Binding Submit, Mode=OneWay}"
                                          IsCheckedChanged="OnSubmitChanged"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Dismiss" Width="100" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:ActionEditor">
                                <CheckBox IsChecked="{Binding Dismiss, Mode=OneWay}"
                                          IsCheckedChanged="OnDismissChanged"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="48" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:ActionEditor">
                                <Button Content="×" Padding="8,2"
                                        Click="OnRemove"
                                        ToolTip.Tip="Remove action"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
