<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="200"
             x:Class="TaskBlaster.Views.VisibilityEditorView">
    <Border BorderThickness="1" CornerRadius="4" Padding="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <Grid RowDefinitions="Auto,Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="Visibility rules" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button    Grid.Column="1" Name="AddButton" Content="+ Add rule" Click="OnAdd" />
            </Grid>

            <TextBlock Grid.Row="1" FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,6"
                       Text="When the controller field matches the condition, show or hide the listed target fields (comma-separated keys)." />

            <ItemsControl Grid.Row="2" Name="RulesList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
