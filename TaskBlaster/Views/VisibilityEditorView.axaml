<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:forms="clr-namespace:TaskBlaster.Forms"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="200"
             x:Class="TaskBlaster.Views.VisibilityEditorView">
    <Border BorderThickness="1" CornerRadius="4" Padding="12"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <Grid RowDefinitions="Auto,Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="Visibility rules" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button    Grid.Column="1" Name="AddButton" Content="+ Add rule" Click="OnAdd" />
            </Grid>

            <TextBlock Grid.Row="1" FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,8"
                       Text="When the controller field matches the condition, show or hide the listed target fields (comma-separated keys)." />

            <DataGrid Grid.Row="2" Name="RulesGrid"
                      x:DataType="forms:VisibilityRuleEditor"
                      AutoGenerateColumns="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Field" Width="130" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:VisibilityRuleEditor">
                                <TextBox Text="{Binding Field, Mode=OneWay}"
                                         TextChanged="OnFieldChanged"
                                         ToolTip.Tip="Controller field key"
                                         Margin="2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Op" Width="110" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:VisibilityRuleEditor">
                                <ComboBox SelectionChanged="OnOpChanged"
                                          AttachedToVisualTree="OnOpAttached"
                                          ToolTip.Tip="Trigger operator"
                                          Margin="2"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="equals" />
                                    <ComboBoxItem Content="not equal" />
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Value" Width="130" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:VisibilityRuleEditor">
                                <TextBox Text="{Binding Value, Mode=OneWay}"
                                         TextChanged="OnValueChanged"
                                         ToolTip.Tip="Trigger value"
                                         Margin="2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="20" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="→" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Action" Width="100" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:VisibilityRuleEditor">
                                <ComboBox SelectionChanged="OnActionChanged"
                                          AttachedToVisualTree="OnActionAttached"
                                          ToolTip.Tip="Show or hide the target fields when triggered"
                                          Margin="2"
                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="show" />
                                    <ComboBoxItem Content="hide" />
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Targets" Width="*" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:VisibilityRuleEditor">
                                <TextBox Text="{Binding TargetsCsv, Mode=OneWay}"
                                         TextChanged="OnTargetsChanged"
                                         ToolTip.Tip="Comma-separated field keys to show/hide"
                                         Margin="2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="48" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="forms:VisibilityRuleEditor">
                                <Button Content="×" Padding="8,2"
                                        Click="OnRemove"
                                        ToolTip.Tip="Remove rule"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
