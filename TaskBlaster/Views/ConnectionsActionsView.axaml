<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="32"
             x:Class="TaskBlaster.Views.ConnectionsActionsView">
    <StackPanel Orientation="Horizontal" Spacing="4">
        <Button Name="AddButton"      Content="➕ Add"        Click="OnAddClicked" />
        <Button Name="DeleteButton"   Content="🗑 Delete"     IsEnabled="False" Click="OnDeleteClicked" />
        <Rectangle Width="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="6,2" />
        <Button Name="AddFieldButton" Content="➕ Add field"  IsEnabled="False" Click="OnAddFieldClicked" />
    </StackPanel>
</UserControl>
