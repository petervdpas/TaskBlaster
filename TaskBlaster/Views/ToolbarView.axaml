<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="80"
             x:Class="TaskBlaster.Views.ToolbarView">
    <UserControl.Styles>
        <Style Selector="ContentPresenter#ActionsHost Button">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="ContentPresenter#ActionsHost ToggleButton">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
    </UserControl.Styles>
    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
        <StackPanel Orientation="Vertical">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Chat" FontSize="12" VerticalAlignment="Center" Name="ChatToggleLabel" />
                    <ToggleSwitch Name="ChatToggle"
                                  IsChecked="False"
                                  OnContent=""
                                  OffContent=""
                                  MinWidth="0"
                                  Padding="0"
                                  VerticalAlignment="Center"
                                  IsCheckedChanged="OnChatToggleChanged"
                                  ToolTip.Tip="Show or hide the script-scoped Assistant chat panel" />
                    <TextBlock Text="Terminal" FontSize="12" VerticalAlignment="Center" />
                    <ToggleSwitch Name="TerminalToggle"
                                  IsChecked="True"
                                  OnContent=""
                                  OffContent=""
                                  MinWidth="0"
                                  Padding="0"
                                  VerticalAlignment="Center"
                                  IsCheckedChanged="OnTerminalToggleChanged"
                                  ToolTip.Tip="Show or hide the Terminal panel" />
                    <Button Name="ConfigButton" Content="⚙ Settings" Click="OnConfigClicked" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ToggleButton Name="ScriptsMode"     Content="📜 Scripts"     IsChecked="True" Click="OnScriptsModeClicked" />
                    <ToggleButton Name="FormsMode"       Content="📋 Forms"                        Click="OnFormsModeClicked" />
                    <ToggleButton Name="SecretsMode"     Content="🔐 Secrets"                      Click="OnSecretsModeClicked" />
                    <ToggleButton Name="ConnectionsMode" Content="🔗 Connections"                  Click="OnConnectionsModeClicked" />
                    <ToggleButton Name="AssistantMode"   Content="🧠 Assistant"                    Click="OnAssistantModeClicked" />
                </StackPanel>
            </DockPanel>

            <Border Name="ActionsStrip" Padding="8,4,8,6"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    IsVisible="False">
                <ContentPresenter Name="ActionsHost" />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
