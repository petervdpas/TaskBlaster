<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:TaskBlaster.Views"
             mc:Ignorable="d" d:DesignWidth="220" d:DesignHeight="600"
             x:Class="TaskBlaster.Views.SidebarView">
    <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock Grid.Row="0" Name="HeaderLabel" Text="Scripts" FontWeight="SemiBold" Padding="10,8" />
        <views:FilterBoxView Grid.Row="1" Name="Filter" Margin="8,0,8,6" />
        <ListBox Grid.Row="2" Name="ScriptList" SelectionChanged="OnSelectionChanged" />
    </Grid>
</UserControl>
