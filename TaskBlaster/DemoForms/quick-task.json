{
  "title": "Quick task",
  "size": { "width": 420, "height": 300 },
  "fields": [
    { "key": "title",    "type": "text",     "label": "Title",
      "required": true, "placeholder": "Fix the login redirect" },
    { "key": "priority", "type": "select",   "label": "Priority",
      "options": [
        { "value": "low",    "label": "Low" },
        { "value": "normal", "label": "Normal" },
        { "value": "high",   "label": "High" },
        { "value": "urgent", "label": "Urgent" }
      ] },
    { "key": "estimate", "type": "number",   "label": "Estimate (hours)",
      "min": 0, "max": 40, "step": 0.5 },
    { "key": "notes",    "type": "textarea", "label": "Notes", "rows": 3 }
  ],
  "actions": [
    { "id": "save",   "label": "Save",   "submit":  true },
    { "id": "cancel", "label": "Cancel", "dismiss": true }
  ]
}
